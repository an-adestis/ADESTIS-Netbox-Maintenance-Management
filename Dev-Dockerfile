ARG FROM_IMAGE=netboxcommunity/netbox
ARG FROM_TAG=v4.3.7-3.3.0
ARG FROM=${FROM_IMAGE}:${FROM_TAG}
FROM ${FROM}

ENV VIRTUAL_ENV=/opt/netbox/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Plugin-Dateien kopieren
COPY ./adestis_netbox_maintenance_management /source/adestis-netbox-maintenance/adestis_netbox_maintenance_management/
COPY ./setup.py /source/adestis-netbox-maintenance/
COPY ./MANIFEST.in /source/adestis-netbox-maintenance/
COPY ./README.md /source/adestis-netbox-maintenance/
COPY ./docker/requirements-container.txt /source/adestis-netbox-maintenance/
COPY ./docker/configuration/configuration.py /etc/netbox/config/configuration.py

# Plugin und Python-Abhängigkeiten installieren
RUN /usr/local/bin/uv pip install /source/adestis-netbox-maintenance/
RUN /usr/local/bin/uv pip install -r /source/adestis-netbox-maintenance/requirements-container.txt

# Systemabhängigkeiten für WeasyPrint installieren
RUN apt-get update && apt-get install -y \
    libcairo2 \
    libpango-1.0-0 \
    libgdk-pixbuf2.0-0 \
    libffi-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# WeasyPrint installieren
RUN /usr/local/bin/uv pip install weasyprint